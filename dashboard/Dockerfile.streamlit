FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit==1.32.0 \
    plotly==5.20.0 \
    pandas==2.2.1 \
    psycopg2-binary==2.9.9 \
    sqlalchemy==2.0.28

COPY dashboard/app.py .

EXPOSE 8501

CMD ["streamlit", "run", "app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--theme.base=dark"]